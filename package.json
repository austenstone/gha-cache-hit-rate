{
  "name": "gha-cache-hit-rate",
  "version": "0.1.0",
  "description": "GitHub CLI extension to analyze cache hit rates across GitHub Actions workflows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gha-cache-hit-rate": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "github",
    "actions",
    "cache",
    "cli",
    "analytics",
    "workflows",
    "performance"
  ],
  "author": "Austen Stone",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/austenstone/gha-cache-hit-rate.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/css": "^0.9.0",
    "@eslint/js": "^9.30.1",
    "@eslint/json": "^0.12.0",
    "@eslint/markdown": "^6.6.0",
    "@types/node": "^24.0.10",
    "@types/yargs": "^17.0.0",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@octokit/rest": "^20.0.0",
    "yargs": "^17.7.0",
    "cli-table3": "^0.6.0",
    "csv-writer": "^1.6.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.0",
    "p-limit": "^4.0.0",
    "date-fns": "^2.30.0",
    "node-stream-zip": "^1.15.0"
  }
}
